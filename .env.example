# ── Claude (Anthropic) — chave PRÓPRIA do agente de suporte (crédito isolado) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp (Evolution API) — instância do número de suporte ──
EVOLUTION_API_URL=https://sua-evolution.easypanel.host
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=Ativa

# ── Backend BarberZap (edge function de dados do cliente em tempo real) ──
# Base das edge functions do Supabase + o mesmo segredo configurado no Lovable (AGENT_LOOKUP_SECRET)
BARBERZAP_API_URL=https://xfvhrnydfeyjnsskpnkj.supabase.co
AGENT_LOOKUP_SECRET=troque-pelo-mesmo-secret-do-supabase

# ── Memória/sessão (Upstash Redis) — RECOMENDADO ──
# Sem isso, a sessão/ativação fica só em RAM e some se o container reiniciar.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Comportamento ──
# Frase do botão "Quero ajuda" que ativa o agente (normalizada).
ACTIVATION_PHRASE=preciso de ajuda com o barberzap
# Minutos de pausa quando um humano assume a conversa.
HUMAN_PAUSE_MINUTES=30

PORT=3000
